# OpenRouter API key — get one free at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: override the free model (assignment-suggested options below)
# Default works for most accounts; server auto-falls back if blocked
OPENROUTER_MODEL=openrouter/free
# OPENROUTER_MODEL=openrouter/free
# OPENROUTER_MODEL=openai/gpt-oss-120b:free
# OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Server port (default 3001)
PORT=3001

# Leave unset — Vite proxies /api to PORT in dev; production uses relative /api
# VITE_API_URL=
